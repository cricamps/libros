{
  "info": {
    "_postman_id": "7a2b9c3d-6e8f-4b1a-9c5d-tienda-tecnologia",
    "name": "Sumativa 1 - Tienda de Tecnología (Usuarios + Productos)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección completa para el Sistema de Gestión de Pedidos de una Tienda de Tecnología en Línea. Microservicios: Usuarios y Productos. Puerto 8081, ruta base /api."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081/api"
    }
  ],
  "item": [
    {
      "name": "MICROSERVICIO 1 - USUARIOS",
      "item": [
        {
          "name": "01 - Listar todos los usuarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/usuarios",
            "description": "Obtiene todos los usuarios registrados. Respuesta esperada: 200 OK."
          }
        },
        {
          "name": "02 - Buscar usuario por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/usuarios/1",
            "description": "Busca el usuario con id=1. Respuesta esperada: 200 OK o 404 Not Found."
          }
        },
        {
          "name": "03 - Crear usuario ADMIN",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Laura Admin\",\n  \"email\": \"laura.admin@tienda.cl\",\n  \"password\": \"Admin9999\",\n  \"rol\": \"ADMIN\"\n}"
            },
            "url": "{{baseUrl}}/usuarios",
            "description": "Crea un nuevo usuario con rol ADMIN. Respuesta esperada: 201 Created."
          }
        },
        {
          "name": "04 - Crear usuario CLIENTE",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Cliente\",\n  \"email\": \"juan.cliente@gmail.com\",\n  \"password\": \"Cliente0001\",\n  \"rol\": \"CLIENTE\"\n}"
            },
            "url": "{{baseUrl}}/usuarios",
            "description": "Crea un nuevo usuario con rol CLIENTE. Respuesta esperada: 201 Created."
          }
        },
        {
          "name": "05 - Actualizar usuario por ID",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana González Actualizada\",\n  \"email\": \"ana.gonzalez@gmail.com\",\n  \"password\": \"NuevaClave123\",\n  \"rol\": \"CLIENTE\"\n}"
            },
            "url": "{{baseUrl}}/usuarios/2",
            "description": "Actualiza los datos del usuario con id=2. Respuesta esperada: 200 OK o 404 Not Found."
          }
        },
        {
          "name": "06 - Eliminar usuario por ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/usuarios/4",
            "description": "Elimina el usuario con id=4. Respuesta esperada: 204 No Content o 404 Not Found."
          }
        },
        {
          "name": "07 - Login exitoso (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@tienda.cl\",\n  \"password\": \"Admin1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Login con credenciales válidas del administrador. Respuesta esperada: 200 OK con datos del usuario y su rol."
          }
        },
        {
          "name": "08 - Login exitoso (CLIENTE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana.gonzalez@gmail.com\",\n  \"password\": \"Cliente123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Login con credenciales válidas de un cliente. Respuesta esperada: 200 OK con datos del usuario y su rol CLIENTE."
          }
        },
        {
          "name": "09 - Login fallido (contraseña incorrecta)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@tienda.cl\",\n  \"password\": \"claveincorrecta\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Login con contraseña incorrecta. Respuesta esperada: 401 Unauthorized."
          }
        },
        {
          "name": "10 - Crear usuario inválido (sin nombre)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"\",\n  \"email\": \"test@test.com\",\n  \"password\": \"Test1234\",\n  \"rol\": \"CLIENTE\"\n}"
            },
            "url": "{{baseUrl}}/usuarios",
            "description": "Prueba de validación. Nombre vacío. Respuesta esperada: 400 Bad Request."
          }
        },
        {
          "name": "11 - Crear usuario inválido (rol incorrecto)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Usuario Test\",\n  \"email\": \"test2@test.com\",\n  \"password\": \"Test1234\",\n  \"rol\": \"SUPERUSUARIO\"\n}"
            },
            "url": "{{baseUrl}}/usuarios",
            "description": "Prueba de validación. Rol inválido (no es ADMIN ni CLIENTE). Respuesta esperada: 400 Bad Request."
          }
        },
        {
          "name": "12 - Buscar usuario inexistente",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/usuarios/9999",
            "description": "Búsqueda de usuario que no existe. Respuesta esperada: 404 Not Found."
          }
        }
      ]
    },
    {
